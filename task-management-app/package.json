{
  "name": "task-management-app",
  "version": "1.0.0",
  "description": "A MERN stack task management application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "npm start --prefix client",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "install-client": "npm install --prefix client",
    "build": "npm run build --prefix client",
    "heroku-postbuild": "npm run install-client && npm run build"
  },
  "keywords": ["mern", "task", "management", "react", "express", "mongodb"],
  "author": "Chandmanish-web",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.1"
  }
}